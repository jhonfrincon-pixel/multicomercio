# ===========================================
# CONFIGURACIÓN DE LIVO - VARIABLES DE ENTORNO
# ===========================================

# --- Base de Datos Supabase ---
VITE_SUPABASE_URL=tu_url_de_supabase_aqui
VITE_SUPABASE_ANON_KEY=tu_key_anon_de_supabase_aqui

# --- API de Google Gemini (Chatbot) ---
VITE_GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# --- Credenciales de Administrador CRM ---
CRM_ADMIN_EMAIL=admin@livo.com
CRM_ADMIN_PASSWORD=admin123456

# --- Configuración de Marketing ---
VITE_META_PIXEL_ID=tu_pixel_id_de_facebook
VITE_GTM_ID=GTM-XXXXXXX

# --- Configuración de WhatsApp ---
VITE_WHATSAPP_NUMBER=573001234567

# --- Configuración de la Aplicación ---
VITE_APP_NAME=Livo
VITE_APP_URL=https://holalivo.netlify.app
VITE_APP_DESCRIPTION=Productos que mejoran tu vida

# --- Moneda y Configuración Regional ---
VITE_CURRENCY=COP
VITE_COUNTRY=CO
VITE_LOCALE=es-CO

# --- Configuración de Envíos ---
VITE_FREE_SHIPPING_THRESHOLD=150000
VITE_STANDARD_SHIPPING_COST=15000
VITE_EXPRESS_SHIPPING_COST=25000

# --- Configuración de Pago ---
VITE_PAYMENT_GATEWAY=MERCADO_PAGO
VITE_MERCADO_PAGO_PUBLIC_KEY=tu_public_key_de_mercado_pago

# --- Configuración de Email ---
VITE_EMAIL_SERVICE=RESEND
VITE_RESEND_API_KEY=tu_api_key_de_resend
VITE_FROM_EMAIL=noreply@livo.com
VITE_FROM_NAME=Livo

# --- Configuración de Analytics ---
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_HOTJAR_ID=XXXXXX

# --- Configuración de Desarrollo ---
NODE_ENV=development
VITE_LOG_LEVEL=debug
